<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png"
    href="https://res.cloudinary.com/ddgve9rfs/image/upload/v1758451120/Homam-Assets/1758451107953-gallery4.jpg" />
  <title>Gallery - Homam Booking</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <!-- Google Fonts: Spiritual & Temple Style -->
  <link href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Sanskrit&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Lora&display=swap" rel="stylesheet" />

  <!-- AOS CSS (Animate on Scroll) -->
  <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/gallery.css" />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17338028065"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag("js", new Date());

    gtag("config", "AW-17338028065");
  </script>
</head>

<body>
  <!-- Navbar -->
  <%- include('./layouts/navbar') %>

    <!-- Gallery Section -->
    <section id="gallery" class="py-5">
      <div class="container" data-aos="fade-up">
        <h2 class="mb-4 text-center">
          <i class="bi bi-images me-2"></i>Our Gallery
        </h2>
        <p class="text-center mb-5 text-muted">
          Experience the spiritual essence and rituals of Thila Homam through
          our curated gallery.
        </p>

        <div class="gallery-grid">
          <% data.forEach((item, index)=> {
            const url = item.image || item.media;
            const isVideo = url && url.match(/\.(mp4|mov|webm|mkv)$/i);
            %>

            <div class="gallery-item gallery-item-lg">
              <% if (isVideo) { %>
                <video class="preview-video" width="400" autoplay muted loop playsinline
                  controlsList="nodownload noplaybackrate noremoteplayback" disablePictureInPicture
                  >
                  <source src="<%= url %>" type="video/mp4">
                </video>
                <% } else { %>
                  <img src="<%= url %>" alt="Priest performing Thila Homam ritual in Rameswaram" />
                  <% } %>
            </div>

            <% }) %>
        </div>

      </div>
    </section>

    <!-- Footer -->
    <%- include('./layouts/footer') %>

      <!-- Bootstrap JS -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

      <!-- AOS -->
      <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
      <script>
        AOS.init({ duration: 1000, once: true });
      </script>
</body>

</html>